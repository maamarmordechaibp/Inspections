# Dependencies
node_modules/

# Lock file is intentionally not committed: it is generated per-platform and a
# Windows-generated lock omits Linux-only optional deps (@emnapi/* via
# @rolldown/binding-wasm32-wasi), which breaks `npm ci` on the Linux CI runner.
# Without a committed lock, Cloudflare runs `npm install`, which resolves
# correctly on its own platform. The registry is pinned in .npmrc.
package-lock.json

# Build output
out/
dist/

# Auto-generated types
auto-imports.d.ts

# Environment variables (secrets)
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Supabase
supabase/.temp/
